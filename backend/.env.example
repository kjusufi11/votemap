# =============================================
# VoteMap Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — create a local DB named "votemap"
DATABASE_URL=postgresql://localhost:5432/votemap

# ProPublica Congress API (free, get at https://www.propublica.org/datastore/api/propublica-congress-api)
PROPUBLICA_API_KEY=your_propublica_key_here

# Google Civic Information API (free, get at https://console.cloud.google.com)
# Enable "Google Civic Information API" in your project
GOOGLE_CIVIC_API_KEY=your_google_civic_key_here

# Anthropic API (for bias analysis)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Cache TTL in seconds (default: 1 hour for votes, 24hr for members)
CACHE_TTL_VOTES=3600
CACHE_TTL_MEMBERS=86400
