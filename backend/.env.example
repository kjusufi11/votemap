# =============================================
# VoteMatch Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — create a local DB named "votematch"
DATABASE_URL=postgresql://localhost:5432/votematch

# Congress.gov API (free — register at https://api.data.gov/signup/)
CONGRESS_API_KEY=your_congress_api_key_here

# FEC API (free — same api.data.gov registration, can use same key as above)
# Without a key, DEMO_KEY is used (60 req/hr per IP). Results are cached 7 days.
FEC_API_KEY=your_fec_api_key_here

# Google Civic Information API (free — https://console.cloud.google.com)
# Enable "Google Civic Information API" in your project
GOOGLE_CIVIC_API_KEY=your_google_civic_key_here

# Anthropic API (for bias analysis)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Cache TTL in seconds (default: 1 hour for votes, 24hr for members)
CACHE_TTL_VOTES=3600
CACHE_TTL_MEMBERS=86400
